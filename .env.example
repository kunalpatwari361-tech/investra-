# Required for authentication in production. Set at least one.
APP_SESSION_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-long-random-secret
JWT_SECRET=replace-with-a-long-random-secret
AUTH_SECRET=replace-with-a-long-random-secret

MFAPI_BASE_URL=https://api.mfapi.in

# Database for persistent auth/user data in production.
MONGODB_URI=mongodb://127.0.0.1:27017/tradesense
MONGODB_DB_NAME=tradesense
NSE_API_BASE_URL=https://nse-api-ruby.vercel.app
OLLAMA_PHI_URL=http://127.0.0.1:11434
OLLAMA_REASONING_URL=http://127.0.0.1:11434
ROUTER_MODEL=phi3:mini
REASONING_MODEL=mistral:7b-instruct-q2_K

# Standalone Express backend
HOST=0.0.0.0
PORT=3000
DHAN_BASE_URL=https://sandbox.dhan.co/v2
DHAN_ACCESS_TOKEN=your_dhan_access_token
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=openchat:7b

# Optional comma-separated EC2 backend override. Uses the three default EC2 APIs if unset.
NEXT_PUBLIC_EC2_API_SERVERS=http://13.49.67.43:3000,http://13.51.206.231:3000,http://13.51.255.106:3000
